; Godot 4.7 project — thin spatial client for EWSim.
; net/seam_test.gd is the headless socket proof; scenes/Sandbox.tscn is the
; slice-1 step-7 spatial view (radar + target + blips + sliders).

config_version=5

[application]

config/name="EWSim Sandbox"
config/features=PackedStringArray("4.7")
run/main_scene="res://scenes/Sandbox.tscn"

[debug]

settings/stdout/print_fps=false
